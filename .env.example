# Copy to .env.local and fill in.
# These are read by src/lib/siteConfig.ts and the contact API route.

# Where lead-notification emails are sent. Comma-separated for multiple.
# Final business-domain addresses TBD — see README "Open items".
LEAD_RECIPIENT_EMAILS=leads@apexshield.io

# Optional: SMTP credentials for the contact API route.
# If unset, the API route logs the lead and returns 200 in development.
# Wire to your provider of choice (Resend, Postmark, SES, Mailgun, etc.).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="ApexShield Leads <leads@apexshield.io>"

# Public site URL (used for canonical + Open Graph).
NEXT_PUBLIC_SITE_URL=https://apexshield.io

# Optional: privacy-respecting analytics domain (Plausible).
# Leave empty to disable analytics.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
